# app
ENVIRONMENT=dev
CORS_ORIGINS=["http://localhost:5173"]

# auth (REQUIRED)
JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXP_MINUTES=720

# database (REQUIRED)
DATABASE_URL=postgresql+asyncpg://pam:pam@db:5432/pam_ai_contact_center

# redis (required for worker/realtime)
REDIS_URL=redis://redis:6379/0

# twilio / telephony (optional, required to place/transfer real calls)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
WHATSAPP_PHONE_NUMBER=

# email / notifications
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=noreply@pam-ai.local

# llm / stt / tts (optional integrations)
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
